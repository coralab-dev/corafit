# apps/api
NODE_ENV=development
PORT=4000
WEB_APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://corafit-web.vercel.app
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
# Backward-compatible legacy name. Prefer SUPABASE_SERVICE_ROLE_KEY for new deploys.
# SUPABASE_SERVICE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key
DATABASE_URL=postgresql://postgres:password@localhost:5432/corafit
ADMIN_EMAIL=admin@corafit.test
ADMIN_SUPABASE_USER_ID=replace-with-supabase-auth-user-id
ADMIN_NAME=CoraFit Admin
DEV_AUTH_EMAIL=replace-with-local-dev-email
DEV_AUTH_PASSWORD=replace-with-local-dev-password
DEV_AUTH_NAME=Coach Demo
DEV_ORGANIZATION_NAME=CoraFit Demo
# Optional: use an existing token instead of signing in with DEV_AUTH_PASSWORD.
# DEV_AUTH_JWT=paste-a-real-supabase-access-token
# Sensitive session output is hidden unless this is set for a one-time run.
DEV_AUTH_PRINT_SESSION=false
# Remote mutation guard. Keep disabled for local development.
DEV_AUTH_ALLOW_REMOTE_MUTATION=false
# Required only when DEV_AUTH_ALLOW_REMOTE_MUTATION=true.
# DEV_AUTH_EXPECTED_SUPABASE_PROJECT_REF=replace-with-supabase-project-ref

# apps/web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# packages/db
DIRECT_URL=postgresql://postgres:password@localhost:5432/corafit
