generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserPlatformRole {
  user
  admin_saas
}

enum UserStatus {
  active
  suspended
  deleted
}

enum OrganizationType {
  individual
  studio
}

enum OrganizationStatus {
  active
  suspended
  cancelled
}

enum OrganizationMemberRole {
  owner
  coach
}

enum OrganizationMemberStatus {
  active
  invited
  suspended
  removed
}

enum SubscriptionStatus {
  trial
  active
  past_due
  expired
  cancelled
  suspended
}

enum SubscriptionPlanStatus {
  active
  inactive
}

enum ClientOperationalStatus {
  active
  paused
  inactive
  archived
}

enum ClientType {
  presential
  online
  hybrid
}

enum ClientAccessStatus {
  active
  temporarily_locked
  disabled
}

enum FollowUpNoteVisibility {
  private
  visible_to_client
}

model User {
  id             String           @id @default(uuid())
  supabaseUserId String           @unique @map("supabase_user_id")
  platformRole   UserPlatformRole @default(user) @map("platform_role")
  name           String
  email          String           @unique
  phone          String?
  status         UserStatus       @default(active)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  ownedOrganizations  Organization[]       @relation("OrganizationOwner")
  organizationMembers OrganizationMember[]

  @@map("users")
}

model Organization {
  id                        String             @id @default(uuid())
  name                      String
  type                      OrganizationType   @default(individual)
  timezone                  String             @default("America/Mexico_City")
  status                    OrganizationStatus @default(active)
  ownerUserId               String             @map("owner_user_id")
  onboardingCompletedAt     DateTime?          @map("onboarding_completed_at")
  clientPortalPreviewSeenAt DateTime?          @map("client_portal_preview_seen_at")
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime           @updatedAt @map("updated_at")

  owner         User                      @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  members       OrganizationMember[]
  subscription  OrganizationSubscription?
  clients       Client[]
  exercises     Exercise[]
  trainingPlans TrainingPlan[]

  @@map("organizations")
}

model OrganizationMember {
  id             String                   @id @default(uuid())
  organizationId String                   @map("organization_id")
  userId         String                   @map("user_id")
  role           OrganizationMemberRole
  status         OrganizationMemberStatus @default(active)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  assignedClients         Client[]
  createdFollowUpNotes    FollowUpNote[]
  createdTrainingPlans    TrainingPlan[]
  createdPlanAssignments  ClientTrainingPlanAssignment[]

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Client {
  id                    String                  @id @default(uuid())
  organizationId        String                  @map("organization_id")
  assignedCoachMemberId String?                 @map("assigned_coach_member_id")
  name                  String
  phone                 String?
  age                   Int?
  sex                   String?
  clientType            ClientType              @map("client_type")
  mainGoal              String                  @map("main_goal")
  heightCm              Float                   @map("height_cm")
  initialWeightKg       Float                   @map("initial_weight_kg")
  trainingLevel         String?                 @map("training_level")
  injuriesNotes         String?                 @map("injuries_notes")
  generalNotes          String?                 @map("general_notes")
  canRegisterWeight     Boolean                 @default(false) @map("can_register_weight")
  operationalStatus     ClientOperationalStatus @default(active) @map("operational_status")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  organization   Organization                       @relation(fields: [organizationId], references: [id])
  assignedCoach  OrganizationMember?                @relation(fields: [assignedCoachMemberId], references: [id])
  access         ClientAccess?
  followUpNotes  FollowUpNote[]
  assignedPlans  TrainingPlan[]                     @relation("AssignedClient")
  planAssignments ClientTrainingPlanAssignment[]

  @@map("clients")
}

model ClientAccess {
  id             String             @id @default(uuid())
  clientId       String             @unique @map("client_id")
  tokenHash      String?            @unique @map("token_hash")
  pinHash        String?            @map("pin_hash")
  status         ClientAccessStatus @default(active)
  failedAttempts Int                @default(0) @map("failed_attempts")
  lockedUntil    DateTime?          @map("locked_until")
  lastAccessAt   DateTime?          @map("last_access_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  client   Client                @relation(fields: [clientId], references: [id])
  sessions ClientPortalSession[]

  @@map("client_accesses")
}

model ClientPortalSession {
  id               String   @id @default(uuid())
  accessId         String   @map("access_id")
  sessionTokenHash String   @unique @map("session_token_hash")
  invalidated      Boolean  @default(false) @map("invalidated")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  access ClientAccess @relation(fields: [accessId], references: [id])

  @@index([accessId])
  @@index([invalidated])
  @@map("client_portal_sessions")
}

model FollowUpNote {
  id                String                 @id @default(uuid())
  clientId          String                 @map("client_id")
  createdByMemberId String                 @map("created_by_member_id")
  text              String
  visibility        FollowUpNoteVisibility @default(private)
  deletedAt         DateTime?              @map("deleted_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  client    Client             @relation(fields: [clientId], references: [id])
  createdBy OrganizationMember @relation(fields: [createdByMemberId], references: [id])

  @@map("follow_up_notes")
}

model SubscriptionPlan {
  id           String                 @id @default(uuid())
  code         String                 @unique
  name         String
  description  String?
  priceMonthly Float                  @map("price_monthly")
  currency     String                 @default("MXN")
  clientLimit  Int                    @map("client_limit")
  memberLimit  Int                    @map("member_limit")
  features     Json?
  isPublic     Boolean                @default(true) @map("is_public")
  status       SubscriptionPlanStatus @default(active)
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  subscriptions OrganizationSubscription[]

  @@map("subscription_plans")
}

model OrganizationSubscription {
  id                 String             @id @default(uuid())
  organizationId     String             @unique @map("organization_id")
  subscriptionPlanId String             @map("subscription_plan_id")
  status             SubscriptionStatus @default(trial)
  startedAt          DateTime           @map("started_at")
  renewsAt           DateTime?          @map("renews_at")
  cancelledAt        DateTime?          @map("cancelled_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  organization     Organization     @relation(fields: [organizationId], references: [id])
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])

  @@map("organization_subscriptions")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ExerciseStatus {
  active
  inactive
  archived
}

enum ExerciseMediaType {
  image
  video_url
}

enum PrimaryMuscle {
  chest
  back
  legs
  shoulder
  biceps
  triceps
  core
  glute
}

enum Equipment {
  barbell
  dumbbell
  cable
  machine
  bodyweight
  other
}

enum TrainingPlanStatus {
  draft
  active
  archived
}

enum TrainingPlanType {
  template
  assigned_copy
}

enum TrainingDayType {
  training
  rest
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum ClientTrainingPlanAssignmentStatus {
  active
  finished
  removed
}

model Exercise {
  id              String        @id @default(uuid())
  organizationId  String?       @map("organization_id")
  organization    Organization? @relation(fields: [organizationId], references: [id])
  createdByUserId String?       @map("created_by_user_id")

  name             String
  primaryMuscle    PrimaryMuscle      @map("primary_muscle")
  secondaryMuscles String[]           @map("secondary_muscles")
  equipment        Equipment
  instructions     String?
  recommendations  String?
  mediaUrl         String?            @map("media_url")
  mediaType        ExerciseMediaType? @map("media_type")
  status           ExerciseStatus     @default(active)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessionExercises     SessionExercise[]
  alternativeExercises SessionExerciseAlternative[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([status])
  @@map("exercises")
}

model TrainingPlan {
  id                String             @id @default(uuid())
  organizationId    String             @map("organization_id")
  createdByMemberId String             @map("created_by_member_id")
  planType          TrainingPlanType   @default(template) @map("plan_type")
  sourcePlanId      String?            @map("source_plan_id")
  assignedClientId  String?            @map("assigned_client_id")
  name              String
  goal              String?
  level             String?
  durationWeeks     Int                @map("duration_weeks")
  generalNotes      String?            @map("general_notes")
  status            TrainingPlanStatus @default(draft)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  organization        Organization                      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy           OrganizationMember                @relation(fields: [createdByMemberId], references: [id], onDelete: Restrict)
  sourcePlan          TrainingPlan?                     @relation("PlanCopies", fields: [sourcePlanId], references: [id], onDelete: SetNull)
  copies              TrainingPlan[]                    @relation("PlanCopies")
  assignedClient      Client?                           @relation("AssignedClient", fields: [assignedClientId], references: [id], onDelete: SetNull)
  sourceAssignments   ClientTrainingPlanAssignment[]    @relation("AssignmentSource")
  assignedAssignments ClientTrainingPlanAssignment[]    @relation("AssignmentCopy")
  weeks               TrainingPlanWeek[]

  @@map("training_plans")
}

model TrainingPlanWeek {
  id             String   @id @default(uuid())
  trainingPlanId String   @map("training_plan_id")
  weekNumber     Int      @map("week_number")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  trainingPlan TrainingPlan      @relation(fields: [trainingPlanId], references: [id], onDelete: Restrict)
  days         TrainingPlanDay[]

  @@unique([trainingPlanId, weekNumber])
  @@map("training_plan_weeks")
}

model TrainingPlanDay {
  id                 String          @id @default(uuid())
  trainingPlanWeekId String          @map("training_plan_week_id")
  dayOfWeek          DayOfWeek       @map("day_of_week")
  dayOrder           Int?            @map("day_order")
  dayType            TrainingDayType @default(training) @map("day_type")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  week    TrainingPlanWeek @relation(fields: [trainingPlanWeekId], references: [id], onDelete: Restrict)
  session TrainingSession?

  @@unique([trainingPlanWeekId, dayOfWeek])
  @@map("training_plan_days")
}

model TrainingSession {
  id                String   @id @default(uuid())
  trainingPlanDayId String   @unique @map("training_plan_day_id")
  name              String
  description       String?
  coachNote         String?  @map("coach_note")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  day       TrainingPlanDay   @relation(fields: [trainingPlanDayId], references: [id], onDelete: Restrict)
  exercises SessionExercise[]

  @@map("training_sessions")
}

model SessionExercise {
  id                String   @id @default(uuid())
  trainingSessionId String   @map("training_session_id")
  exerciseId        String   @map("exercise_id")
  orderIndex        Int      @map("order_index")
  sets              Int?
  reps              String
  restSeconds       Int?     @map("rest_seconds")
  coachNote         String?  @map("coach_note")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  session      TrainingSession              @relation(fields: [trainingSessionId], references: [id], onDelete: Restrict)
  exercise     Exercise                     @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  alternatives SessionExerciseAlternative[]

  @@unique([trainingSessionId, orderIndex])
  @@map("session_exercises")
}

model SessionExerciseAlternative {
  id                    String   @id @default(uuid())
  sessionExerciseId     String   @map("session_exercise_id")
  alternativeExerciseId String   @map("alternative_exercise_id")
  note                  String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  sessionExercise     SessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Restrict)
  alternativeExercise Exercise        @relation(fields: [alternativeExerciseId], references: [id], onDelete: Restrict)

  @@index([sessionExerciseId])
  @@map("session_exercise_alternatives")
}

model ClientTrainingPlanAssignment {
  id                   String                            @id @default(uuid())
  clientId             String                            @map("client_id")
  sourceTrainingPlanId String                            @map("source_training_plan_id")
  assignedPlanId       String                            @map("assigned_plan_id")
  assignedByMemberId   String                            @map("assigned_by_member_id")
  startDate            DateTime                          @map("start_date")
  endedAt              DateTime?                         @map("ended_at")
  status               ClientTrainingPlanAssignmentStatus @default(active)
  createdAt            DateTime                          @default(now()) @map("created_at")
  updatedAt            DateTime                          @updatedAt @map("updated_at")

  client       Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  sourcePlan   TrainingPlan       @relation("AssignmentSource", fields: [sourceTrainingPlanId], references: [id], onDelete: Restrict)
  assignedPlan TrainingPlan       @relation("AssignmentCopy", fields: [assignedPlanId], references: [id], onDelete: Restrict)
  assignedBy   OrganizationMember @relation(fields: [assignedByMemberId], references: [id], onDelete: Restrict)

  @@map("client_training_plan_assignments")
}
